# ══════════════════════════════════════════════════════════════
#  Praveen K Portfolio — Environment Variables
#  Copy this file to .env and fill in your actual values.
#  NEVER commit the real .env to version control.
# ══════════════════════════════════════════════════════════════

# ── Flask ─────────────────────────────────────────────────────
FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-64-char-string-in-production
JWT_SECRET_KEY=change-this-jwt-secret-to-something-very-random

# ── MongoDB Atlas ─────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=praveen_portfolio

# ── Google Gemini AI ─────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Admin Panel ───────────────────────────────────────────────
ADMIN_USERNAME=praveen_admin
ADMIN_PASSWORD=change_this_strong_password_123!

# ── Email Notifications (optional) ───────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
NOTIFY_EMAIL=praveenkicha01@gmail.com

# ── Security ─────────────────────────────────────────────────
ALLOWED_ORIGINS=https://praveenk.dev

# ── Rate Limiting (optional Redis URL) ───────────────────────
# REDIS_URL=redis://localhost:6379

# ── Port (for Render / Railway) ───────────────────────────────
PORT=5000
